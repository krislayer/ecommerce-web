# WhatsApp Config
# Formato: código de país + número (sin espacios, guiones, paréntesis, ni el símbolo +)
# Ejemplo para Guatemala: 50256995320 (502 = código país, 56995320 = número)
NEXT_PUBLIC_WHATSAPP_NUMBER=50256995320

# URL pública del sitio (SEO: sitemap, robots, Open Graph, JSON-LD)
# En Vercel suele inferirse; definir explícitamente en producción.
# Ejemplo: https://quechulito.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
